{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "noEmit": true,
    "skipLibCheck": true,
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["vitepress/client"]
  },
  "include": [
    ".vitepress/**/*.ts",
    ".vitepress/**/*.mts",
    ".vitepress/**/*.d.ts",
    ".vitepress/**/*.vue",
    "posts/**/*.vue"
  ],
  "exclude": [
    "node_modules",
    ".vitepress/cache",
    ".vitepress/dist",
    ".vitepress/.temp"
  ]
}
